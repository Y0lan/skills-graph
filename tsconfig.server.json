{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist-server",
    "rootDir": ".",
    "types": ["node"],
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "declaration": false,
    "verbatimModuleSyntax": false,
    "jsx": "react-jsx"
  },
  "include": ["server/**/*.ts", "server/**/*.tsx", "src/data/team-roster.ts"],
  "exclude": ["server/__tests__/**"]
}
