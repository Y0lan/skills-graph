{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist-server",
    "rootDir": ".",
    "types": ["node"],
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "declaration": false,
    "verbatimModuleSyntax": false
  },
  "include": ["server/**/*.ts", "src/data/team-roster.ts"]
}
